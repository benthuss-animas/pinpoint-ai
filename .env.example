# Copy this to server/.env and fill in your values

# GitHub Personal Access Token (needs repo scope)
GITHUB_TOKEN=ghp_your_token_here

# The GitHub repo where issues will be filed
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo-name

# Label applied to all Pinpoint issues (default: pinpoint)
GITHUB_LABEL=pinpoint

# Port for the local server (default: 3456)
PORT=3456
